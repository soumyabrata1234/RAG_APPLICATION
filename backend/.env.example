# Server
PORT=5000
NODE_ENV=development

# Google Gemini


# Pinecone
PINECONE_API_KEY=your-pinecone-api-key
PINECONE_INDEX_NAME=pdf-rag-index
PINECONE_CLOUD=aws
PINECONE_REGION=us-east-1

# File Upload
MAX_FILE_SIZE_MB=50
UPLOAD_DIR=./uploads

# Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# CORS
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
